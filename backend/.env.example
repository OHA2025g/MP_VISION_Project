MONGO_URL="mongodb://localhost:27017"
DB_NAME="test_database"
# * = localhost:3000, 127.0.0.1:3000, plus FRONTEND_URL. Or comma-separated origins (no *) for strict lists.
CORS_ORIGINS="*"
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_EMAIL="admin@mpvision.gov.in"
ADMIN_PASSWORD="change-me"
EMERGENT_LLM_KEY=
# Must match the browser origin where the UI is opened (scheme + host, no path). Required for CORS + cookies in production.
FRONTEND_URL="http://localhost:3000"
